{\n  "name": "semantic-version-comparator",\n  "version": "1.0.0",\n  "description": "Simple SemVer 2.0.0 comparator with web UI",\n  "main": "dist/index.js",\n  "scripts": {\n    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",\n    "backend:dev": "nodemon --exec ts-node src/backend/server.ts",\n    "frontend:dev": "cd src/frontend && npm run dev",\n    "build": "npm run build:backend && npm run build:frontend",\n    "build:backend": "tsc",\n    "build:frontend": "cd src/frontend && npm run build",\n    "start": "node dist/backend/server.js"\n  },\n  "dependencies": {\n    "express": "^4.18.2",\n    "cors": "^2.8.5"\n  },\n  "devDependencies": {\n    "typescript": "^5.0.0",\n    "ts-node": "^10.9.0",\n    "nodemon": "^3.0.0",\n    "concurrently": "^8.0.0",\n    "@types/express": "^4.17.0",\n    "@types/node": "^20.0.0"\n  }\n}